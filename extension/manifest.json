{
  "manifest_version": 3,
  "name": "오블 — 오늘의블로그",
  "version": "1.1",
  "description": "AI로 블로그 원고를 생성하고 네이버 블로그에 자동 삽입합니다. — 오늘의블로그",
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite", "tabs", "sidePanel"],
  "host_permissions": [
    "*://blog.naver.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://*.cloudfunctions.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "오블 열기"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://blog.naver.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
